{
  "name": "threedviewer",
  "version": "3.2.0",
  "license": "AGPL-3.0-or-later",
  "engines": {
    "node": "^22.0.0",
    "npm": "^10.5.0"
  },
  "scripts": {
    "prebuild": "node scripts/clean-build.mjs && node scripts/copy-decoders.mjs",
    "build": "vite build",
    "postbuild": "npm run size:check",
    "dev": "vite --mode development build",
    "watch": "vite --mode development build --watch",
    "copy-decoders": "node scripts/copy-decoders.mjs",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "stylelint": "stylelint src/**/*.vue src/**/*.scss src/**/*.css",
    "stylelint:fix": "stylelint src/**/*.vue src/**/*.scss src/**/*.css --fix",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "test:smoke": "npm run build && playwright test tests/smoke",
    "test:smoke:headed": "npm run build && playwright test tests/smoke --headed",
    "size:check": "node scripts/check-bundle-size.mjs",
    "format:check": "node scripts/check-format-parity.mjs",
    "i18n:check": "node scripts/check-i18n.mjs",
    "i18n:sync": "node scripts/check-i18n.mjs --sync-en --prune",
    "test:match": "node scripts/test-match-helpers.mjs",
    "validate": "npm run lint && npm run stylelint && npm run format:check && npm run i18n:check && npm run test:match && npm run test",
    "ci": "npm run lint && npm run stylelint && npm run build && npm run test:smoke",
    "clean": "rm -rf node_modules/.cache dist .phpunit.cache coverage test-results playwright-report",
    "clean:all": "npm run clean && rm -rf node_modules",
    "setup": "npm install && npm run copy-decoders",
    "audit": "npm audit --audit-level=high",
    "audit:fix": "npm audit fix",
    "outdated": "npm outdated"
  },
  "type": "module",
  "browserslist": [
    "extends @nextcloud/browserslist-config"
  ],
  "dependencies": {
    "@nextcloud/axios": "^2.2.0",
    "@nextcloud/dialogs": "^7.2.0",
    "@nextcloud/router": "^3.1.0",
    "@nextcloud/vue": "^9.6.0",
    "three": "^0.184.0",
    "vue": "^3.5.32",
    "vue-material-design-icons": "^5.3.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-proposal-object-rest-spread": "^7.20.7",
    "@babel/plugin-syntax-dynamic-import": "^7.8.3",
    "@babel/plugin-transform-runtime": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-typescript": "^7.28.5",
    "@nextcloud/browserslist-config": "^3.1.2",
    "@nextcloud/eslint-config": "^8.4.2",
    "@nextcloud/stylelint-config": "^3.1.1",
    "@nextcloud/vite-config": "^2.5.2",
    "@playwright/test": "^1.59.1",
    "@types/jest": "^30.0.0",
    "babel-jest": "^29.7.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "postcss": "^8.4.49",
    "postcss-html": "^1.8.1",
    "postcss-scss": "^4.0.9",
    "sass-embedded": "^1.99.0",
    "stylelint": "^16.26.1",
    "stylelint-config-standard-scss": "^14.0.0",
    "stylelint-order": "^6.0.3",
    "stylelint-scss": "^6.14.0",
    "vite": "^7.3.1"
  },
  "overrides": {
    "postcss": "^8.4.49",
    "fast-xml-parser": ">=5.5.7"
  },
  "resolutions": {
    "postcss": "^8.4.49",
    "fast-xml-parser": ">=5.5.7"
  },
  "babel": {
    "presets": [
      [
        "@babel/preset-env",
        {
          "targets": {
            "node": "current"
          }
        }
      ],
      "@babel/preset-typescript"
    ]
  },
  "jest": {
    "testEnvironment": "jsdom",
    "transform": {
      "^.+\\.(js|jsx|ts|tsx)$": "babel-jest"
    },
    "transformIgnorePatterns": [
      "/node_modules/(?!three)"
    ],
    "testPathIgnorePatterns": [
      "<rootDir>/tests/playwright/",
      "<rootDir>/tests/smoke/"
    ]
  }
}
